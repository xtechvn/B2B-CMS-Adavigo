@using ADAVIGO_FRONTEND.ViewModels
@model HotelRoomGridModel
@{
    int nights = (int)ViewBag.Nights;
}
<style>
    .swiper-button-next, .swiper-button-prev {
        font-size: 27px;
        opacity: 0.7;
    }
    .night-status-list {
        display: grid;
        grid-template-columns: repeat(3, auto);
        gap: 10px 6px;
        justify-content: center;
        margin-bottom: 10px;
    }
    .night-status-item {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .night-status-date {
        font-size: 11px;
        color: #909bb5;
        font-weight: 600;
        margin-bottom: 4px;
    }
    .night-status-circle {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background-color: #1caf4b;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
    }
    .night-status-circle.simple-status {
        width: auto;
        min-width: 26px;
        padding: 0 4px;
        border-radius: 4px;
    }
</style>
<div style="display:none;" id="hotel_detail_surcharge">
    @Html.Raw(Model == null || Model.surcharge == null ? "" : Model.surcharge)
</div>

@if (Model != null && Model.rooms.Any())
{
    <input type="hidden" id="hotel_grid_cache_search" value="@Model.cache_id" />
    <input type="hidden" id="hotel_grid_cache_night_time" value="@Model.night_time" />

    if (Model.rooms != null && Model.rooms.Any())
    {
        var room_list = new List<HotelRoomDataModel>();
        room_list.AddRange(Model.rooms.Where(s => s.min_price > 0).OrderBy(s => s.min_price));
        room_list.AddRange(Model.rooms.Where(s => s.min_price == 0));

        <div class="flex mb8 hidden-xs" style="padding: 0 16px; font-size: 11px; font-weight: bold; color: #555; text-transform: uppercase; align-items: center;">
            <div style="width: 220px; margin-right: 15px;">Loại phòng</div>
            <div style="flex: 1;">
                 <div class="row flex" style="align-items: center;">
                     <div class="col-4"></div>
                     <div class="col-3 text-center"><span style=" padding-bottom: 5px; display: inline-block;">Tình trạng từng đêm</span></div>
                     <div class="col-2 text-center">Giá net</div>
                     <div class="col-3 text-right">Hành động</div>
                 </div>
            </div>
        </div>

        foreach (var item in room_list)
        {
            var image_url = "/images/graphics/thumb1x1.jpg";
            var is_has_image = false;
            if (item.img_thumb != null && item.img_thumb.Any())
            {
                var image_datas = item.img_thumb.Where(s => !string.IsNullOrEmpty(s.url)).FirstOrDefault();
                if (image_datas != null)
                {
                    is_has_image = true;
                    image_url = image_datas.url;
                }
            }

            <div class="bg-white pd-16 radius10 mb8 room_detail">
                <div class="article-itemt">
                    <div class="article-thumb">
                        @if (is_has_image)
                        {
                            @* <div class="slide-image-package">
                                <div class="swiper-container">
                                <div class="swiper-wrapper">
                                @foreach (var img in image_datas)
                                {
                                <div class="swiper-slide">
                                <a class="cursor-pointer" onclick="_hotel.redirectToDetail(this)">
                                <img class="img_rechange_url" src="" data-url="@img.url" alt="">
                                </a>
                                </div>
                                }
                                </div>
                                </div>
                                <div class="swiper-button-prev"><i class="fa fa-angle-left"></i></div>
                                <div class="swiper-button-next"><i class="fa fa-angle-right"></i></div>
                                </div>*@
                            <a class="thumb_img thumb_5x4">
                                <img class="img_rechange_url" src="" data-url="@image_url" alt="">
                            </a>
                        }
                        else
                        {
                            <a class="thumb_img thumb_5x4">
                                <img src="@image_url" alt="">
                            </a>
                        }
                    </div>
                    <div class="article-content" style="flex: 1; width: 100%;">
                        <div class="row flex" style="align-items: center;">
                            <div class="col-4">
                               @*  @if (item.remainming_room <= 5)
                                {
                                    <div class="tag-title flex mb5">
                                        <span class="orange">Sắp hết phòng</span>
                                    </div>
                                }
                                else if (item.remainming_room <= 0)
                                {
                                    <div class="tag-title flex mb5">
                                        <span class="red">Hết phòng</span>
                                    </div>
                                } *@

                                <h3 class="title_new hotel_room_name" style="font-size: 14px; margin-bottom: 5px;">
                                    @($"{item.name}")
                                </h3>
                                <div class="gray txt_12 mb5">
                                    <i class="fa fa-user"></i> @item.max_adult Người lớn 
                                    @if(item.max_child > 0) { <span><i class="fa fa-child"></i> @item.max_child Trẻ em</span> }
                                </div>
                            </div>
                            
                            <div class="col-3 text-center">
                                <div class="night-status-list placeholder box-placeholder room-night-status-list" data-room-id="@item.id" style="justify-content: center; margin-bottom: 0;">
                                </div>
                            </div>

                            <div class="col-2 text-center">
                                @if (item.min_price > 0)
                                {
                                    <div class="txt_16 bold dynamic_price" data-amount="@item.min_price" data-night="@nights">@((item.min_price / nights).ToString("N0")) đ</div>
                                    
                                }
                                else
                                {
                                    <div class="txt_16 bold">Giá liên hệ</div>
                                }
                            </div>

                            <div class="col-3 text-right">
                                @if (item.min_price > 0)
                                {
                                    <a class="btn-default cursor-pointer choose-room btn__toggle_room_package mb5" style="padding: 6px 12px; font-size: 13px; display: block;" data-toggle="collapse" data-target="#room-info-@item.id" data-id="@item.id" data-code="@item.code">Chọn phòng</a>
                                }
                                <a class="btn btn-default blue full size btn__show_popup_room" style="display: inline-block; margin-top: 5px;">Xem chi tiết</a>
                                <div class="popup hidden">
                                    <div class="article-thumb">
                                        <a class="thumb_img thumb_5x4" href="#">
                                            <img src="/images/graphics/thumb1x1.jpg" alt="">
                                        </a>
                                    </div>
                                    <div class="article-content">
                                        <h3 class="title_new">
                                            <strong>@item.name</strong>
                                        </h3>
                                        <p class="mb10">
                                            Phòng tiêu chuẩn dành cho @item.max_adult người lớn
                                            @if (@item.max_child > 0)
                                            {
                                                <nw>/ @item.max_child trẻ em</nw>
                                            }.
                                            <br />Phụ thu theo độ tuổi
                                        </p>
                                        <div>@item.description</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="info-room collapse placeholder scrollbar-height" id="room-info-@item.id" style="max-height:400px;">
                </div>
            </div>
        }
    }
}
else
{
    <p class="no-result">Hệ thống không tìm thấy kết quả</p>
}



