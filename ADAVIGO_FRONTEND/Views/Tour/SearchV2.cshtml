@using ADAVIGO_FRONTEND.Models.Tour.TourListing
@using LIB.Utilities.Common
@{
    ViewData["Title"] = "Tìm kiếm Tour V2";
    int? start = (int?)ViewBag.Start;
    int? end = (int?)ViewBag.End;
    int? type = (int?)ViewBag.Type;
    TourListingResponseExtensionV2 listing = (TourListingResponseExtensionV2)ViewBag.List;
    string domain = (string)ViewBag.StaticDomain;
}
<input id="filter-url" style="display:none;"
       data-start="@(start == null ? "" : ((int)start).ToString())"
       data-end="@(end == null ? "" : ((int)end).ToString())"
       data-type="@(type == null ? "" : ((int)type).ToString())" />

<style>
    .tour-table {
        border: 1px solid #e8e8e8;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
    }

    .tour-table table {
        margin-bottom: 0;
    }

    .tour-table thead th {
        background: #fafafa;
        color: #17346b;
        font-size: 13px;
        text-align: center;
        vertical-align: middle;
        font-weight: 600;
    }

    .tour-table tbody td {
        vertical-align: middle;
        text-align: center;
    }

    .tour-code {
        color: #2d5bd1;
        font-weight: 600;
    }

    .price {
        color: red;
        font-weight: bold;
        font-size: 18px;
    }

    .commission {
        color: #2f66d7;
        font-weight: 600;
    }

    .detail-row td {
        padding: 0 !important;
        background: #fff;
    }

    .detail-content {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1.2fr 1fr;
        gap: 25px;
        padding: 25px;
        border-top: 1px solid #eee;
        text-align: left;
    }

    .detail-title {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .summary-item {
        color: #20a745;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .badge-custom {
        display: inline-block;
        background: #edf4ff;
        color: #2f66d7;
        padding: 8px 15px;
        border-radius: 6px;
    }

    .detail-content ul {
        padding-left: 18px;
        margin: 0;
    }

    .detail-content li {
        margin-bottom: 10px;
    }

    .flight-title {
        color: #2d5bd1;
        font-weight: bold;
        margin-top: 10px;
    }

    .book-btn {
        background: #0d6efd;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 12px 45px;
        font-weight: 600;
    }

    .book-btn:hover {
        background: #0b5ed7;
    }

    .note {
        color: #555;
    }

    .action-link {
        display: block;
        color: #2d5bd1;
        text-decoration: none;
    }

    .action-link:hover {
        text-decoration: underline;
    }
</style>
<section class="main-container clearfix">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item active" aria-current="page">Tìm kiếm Tour</li>
    </ol>
    <div class="mb-3">
        <h2 class="title-cate">Danh sách tour</h2>
    </div>
    <!-- Filter Bar -->
    <div class="bg-white radius_10 pd-20 mb-20">
        <div class="row align-items-center">
            <div class="col-md-2 mb-2 mb-md-0">
                <div class="">
                    <input type="text" id="fromdate" class="datepicker-input form-control" placeholder="Từ ngày">
                </div>
            </div>
            <div class="col-md-2 mb-2 mb-md-0">
                <div class="">
                    
                    <input type="text" id="todate" class="datepicker-input form-control" placeholder="Đến ngày">
                </div>
            </div>
            <div class="col-md-2 mb-2 mb-md-0">
                <div class="i">
                    <select id="month" class="form-control" style="width:100%">
                        <option value="0">Tháng khởi hành</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">Tháng @i</option>
                        }
                    </select>
                </div>
            </div>
             <div class="col-md-2 mb-2 mb-md-0">
                <div class="">
                    <select id="to" class="form-control" style="width:100%">
                    
                    </select>
                </div>
            </div>
            <div class="col-md-2 mb-2 mb-md-0" style="display:none;">
                <div class="">
                    <input type="text" id="tourname" placeholder="Nhập tên tour hoặc mã tour..." class="form-control">
                </div>
            </div>
            <div class="col-md-2 mb-2 mb-md-0" style="display:none;">
                <div class="">
                    <select id="from" class="form-control" style="width:100%;display:none;">
                    
                    </select>
                </div>
            </div>
           
            
        </div>
        <div class="row align-items-center mt-2">
            <div class="col-md-6">
                <div class="d-flex gap-3">
                    <label class="confir_res square mb-0">
                        No shopping
                        <input type="checkbox" id="noShopping" value="1">
                        <span class="checkmark"></span>
                    </label>
                    <label class="confir_res square mb-0" style="margin-left: 10px;">
                        Ngày lễ / Tết
                        <input type="checkbox" id="isHoliday" value="1">
                        <span class="checkmark"></span>
                    </label>
                   
                </div>
            </div>
            <div class="col-md-6 text-right">
                <button id="btn-search" class="btn btn-primary">Tìm kiếm</button>
            </div>
        </div>
    </div>

    <!-- Results Header -->
    

    <!-- Tour List -->
    <div id="tour-list">
        @if (listing.data != null && listing.data.Count > 0)
        {
            <div class="flex space-between align-items-center mb-20">
                <div class="bold">Tìm thấy @(listing.data?.Count ?? 0) tour</div>
    
             </div>
            foreach (var item in listing.data)
            {
                <div class="tour-table mb-4">
                    <table class="table table-bordered align-middle mb-0">
                        <thead>
                            <tr>
                                <th>STT</th>
                                <th>MÃ TOUR</th>
                                <th>HÀNH TRÌNH TOUR</th>
                                <th>THỜI GIAN</th>
                                @* <th>HÃNG BAY</th> *@
                                <th>NGÀY KHỞI HÀNH</th>
                                <th>NGÀY KẾT THÚC</th>
                                <th>GIÁ TOUR</th>
                                <th>SỐ CHỖ CÒN</th>
                                <th>THAO TÁC</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr class="tour-item">
                                <td>@(listing.data.IndexOf(item) + 1)</td>

                                <td>
                                    @item.tourCode
                                </td>

                                <td class="text-left">
                                    @item.tourName
                                </td>

                                <td>
                                    @item.days N @(item.days - 1) Đ
                                </td>
@* 
                                <td>
                                    @item.goTransportProvider
                                </td> *@

                                <td>
                                    @(item.startDate?.ToString("dd/MM/yyyy"))
                                </td>

                                <td>
                                    @(item.endDate?.ToString("dd/MM/yyyy"))
                                </td>

                                <td class="price">
                                    @item.minPrice?.ToString("N0")
                                </td>

                                <td>
                                    <span class="bold">
                                        @item.availableQuantity
                                    </span>
                                </td>

                                <td>
                                    <a href="javascript:;" class="action-link toggle-detail">
                                        Xem lịch trình
                                    </a>

                                   @* <a href="/tour/san-pham/@CommonHelper.RemoveUnicode(item.tourName).Trim().ToLower().Replace(" ","-")--@item.id" class="action-link mt-2">
                                        Xem chi tiết
                                    </a> *@ 

                                    <a href="/tour/order?id=@item.id&package=@item.tourDepartureId"
                                    class="btn btn-primary btn-sm mt-2" style="background: #0d6efd; border-color: #0d6efd;">
                                        Đặt tour
                                    </a>
                                </td>
                            </tr>

                            <tr class="detail-row" style="display:none;">
                                <td colspan="10">
                                    <div class="detail-content">
                                        <!-- Lịch trình -->
                                        <div>
                                            <div class="detail-title">Lịch trình tóm tắt</div>
                                            @if (item.note != null && !string.IsNullOrEmpty(item.note))
                                            {
                                                <div class="summary-item">
                                                    <i class="fa-solid fa-paperclip"></i>
                                                    <a href="@item.note" style="color: inherit; text-decoration: none;">Chi tiết lịch trình tour</a>
                                                </div>
                                            }

                                            @if(item.isAllowDepositOnline == 1)
                                            {
                                                <div class="badge-custom mb-2">
                                                    <i class="fa-solid fa-tag"></i> No shopping
                                                </div>
                                            }

                                            @if(item.isAllowReserveOnline == 1)
                                            {
                                                <div class="badge-custom mb-2">
                                                    <i class="fa-solid fa-tag"></i> Ngày lễ / tết
                                                </div>
                                            }
                                        </div>

                                        <!-- Dịch vụ -->
                                        <div class="service-tabs-container">
                                            <div class="detail-title">Dịch vụ bao gồm</div>
                                            
                                            <ul class="dotted select-tab-tab tab-content-1" style="@(!(item == null || item.include == null || item.include.Trim() == "")?"":"display:none;")">
                                                @(Html.Raw((item.include == null || item.include.Trim() == "" ? "" : item.include)))
                                            </ul>
                                           
                                        </div>

                                        <!-- Chuyến bay -->
                                        <div>
                                            <div class="detail-title">Thông tin chuyến bay / khách sạn</div>

                                            <div class="flight-title">Chuyến đi</div>
                                            <div>
                                                @item.goTransportProvider &nbsp; @item.goStartPointName → @item.goEndPointName &nbsp; @(item.goDepartureDate?.ToString("dd/MM/yyyy HH:mm"))
                                            </div>

                                            <div class="flight-title mt-3">Chuyến về</div>
                                            <div>
                                                @item.returnTransportProvider &nbsp; @item.returnStartPointName → @item.returnEndPointName &nbsp; @(item.returnDepartureDate?.ToString("dd/MM/yyyy HH:mm"))
                                            </div>
                                        </div>

                                        <!-- Ghi chú -->
                                        <div class="d-flex flex-column justify-content-between">
                                            <div>
                                                <div class="detail-title">Ghi chú</div>
                                                <div class="note mb-3">
                                                    @if(item.availableQuantity > 0)
                                                    {
                                                        <span class="badge badge-success" style="font-size: 14px;">Còn chỗ</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-danger" style="font-size: 14px;">Hết chỗ</span>
                                                    }
                                                </div>
                                            </div>

                                            <a href="/tour/order?id=@item.id&package=@item.tourDepartureId" class="book-btn text-center text-white" style="text-decoration: none;">
                                                <i class="fa-solid fa-calendar-days"></i> Đặt tour
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            <div class="search-null center mb40">
                <div class="mb24">
                    <img src="/images/graphics/icon-search.png" alt="">
                </div>
                <h2 class="title txt_24">Không tìm thấy kết quả</h2>
                <div class="gray">Chúng tôi không tìm thấy thông tin mà bạn cần, vui lòng thử lại</div>
            </div>
        }
    </div>

    <!-- Loading Indicator -->
    <div id="loading-indicator" class="center mb40" style="display:none;">
        
        <div>Đang tải thêm...</div>
    </div>
</section>
@section scripts {
    <script type="text/javascript" src="~/js/modules/tour/constants.js"></script>
    <script type="text/javascript" src="~/js/modules/tour/global.js"></script>
    <script type="text/javascript" src="~/js/modules/tour/searchV2.js"></script>
}
